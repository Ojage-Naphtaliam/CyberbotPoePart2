<Window x:Class="CyberChat.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CyberChat — Cybersecurity Awareness Bot 🇿🇦"
        Height="750" Width="900" MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryDarkBrush}"
        Loaded="Window_Loaded">
    
    <Window.Resources>
        <!-- Send Button Style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4FF" Offset="0"/>
                        <GradientStop Color="#00FF88" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#0A0E1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox Style -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="CaretBrush" Value="#00D4FF"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER: ASCII Art Logo ═══ -->
        <Border Grid.Row="0" Padding="10,10,10,5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0A0E1A" Offset="0"/>
                    <GradientStop Color="#0F1B2D" Offset="0.5"/>
                    <GradientStop Color="#0A0E1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="AsciiArtHeader" Grid.Row="0"
                           FontFamily="Consolas" FontSize="9"
                           Foreground="{StaticResource AccentCyanBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Padding="0,5,0,2"/>
                
                <Border Grid.Row="1" Height="2" Margin="20,5,20,0" CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00D4FF" Offset="0.3"/>
                            <GradientStop Color="#00FF88" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ CHAT AREA ═══ -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Padding="15,10" Background="Transparent">
            <ItemsControl x:Name="ChatItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border x:Name="MessageBorder"
                                    MaxWidth="580" Padding="14,10"
                                    CornerRadius="14"
                                    Margin="0,2">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock x:Name="SenderText" Text="{Binding Sender}" 
                                                   FontWeight="SemiBold" FontSize="11"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding TimeDisplay}" 
                                                   FontSize="10" Opacity="0.6"
                                                   Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" 
                                               FontSize="13.5" LineHeight="20"
                                               Foreground="{StaticResource TextLightBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <DataTemplate.Triggers>
                            <!-- User messages: right-aligned, green-tinted -->
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="MessageBorder" Property="Background" Value="{StaticResource UserBubbleBrush}"/>
                                <Setter TargetName="MessageBorder" Property="BorderBrush" Value="#2D5A4A"/>
                                <Setter TargetName="MessageBorder" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="SenderText" Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                            </DataTrigger>
                            <!-- Bot messages: left-aligned, blue-tinted -->
                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                <Setter TargetName="MessageBorder" Property="HorizontalAlignment" Value="Left"/>
                                <Setter TargetName="MessageBorder" Property="Background" Value="{StaticResource BotBubbleBrush}"/>
                                <Setter TargetName="MessageBorder" Property="BorderBrush" Value="#2A3F6A"/>
                                <Setter TargetName="MessageBorder" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="SenderText" Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ INPUT AREA ═══ -->
        <Border Grid.Row="2" Padding="15,10,15,15">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#111827" Offset="0"/>
                    <GradientStop Color="#0A0E1A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="UserInputTextBox" Grid.Column="0"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0,0,10,0"
                         KeyDown="UserInputTextBox_KeyDown"
                         ToolTip="Type your message here..."/>
                
                <Button x:Name="SendButton" Grid.Column="1"
                        Content="Send ➤"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
